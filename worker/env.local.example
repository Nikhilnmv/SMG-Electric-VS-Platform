# ============================================
# WORKER - LOCAL DEVELOPMENT ENVIRONMENT
# ============================================
# Copy this file to .env for local development
# cp env.local.example .env

# Environment
NODE_ENV=development
ENVIRONMENT=local

# ============================================
# DATABASE - Local Docker PostgreSQL
# ============================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vs_platform?schema=public

# Alternative: Individual connection parameters
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vs_platform
DB_USER=postgres
DB_PASSWORD=postgres

# ============================================
# REDIS - Local Docker Redis
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# STORAGE - Local Filesystem
# ============================================
STORAGE_MODE=local
UPLOADS_DIR=../backend/uploads

# AWS S3 (not used in local mode)
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=

# ============================================
# WORKER CONFIGURATION
# ============================================
TRANSCODING_CONCURRENCY=2
LIVE_STREAM_CONCURRENCY=1

# ============================================
# TEMPORARY DIRECTORY
# ============================================
TEMP_DIR=/tmp/transcode
