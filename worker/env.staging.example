# ============================================
# WORKER - STAGING CLOUD ENVIRONMENT
# ============================================
# Copy this file to .env for staging deployment
# cp env.staging.example .env
# Then fill in the actual values from your cloud infrastructure

# Environment
NODE_ENV=production
ENVIRONMENT=staging

# ============================================
# DATABASE - AWS RDS PostgreSQL
# ============================================
# Replace with your RDS endpoint
DATABASE_URL=postgresql://username:password@your-rds-endpoint.region.rds.amazonaws.com:5432/vs_platform?schema=public

# Alternative: Individual connection parameters
DB_HOST=your-rds-endpoint.region.rds.amazonaws.com
DB_PORT=5432
DB_NAME=vs_platform
DB_USER=your_db_username
DB_PASSWORD=your_db_password

# ============================================
# REDIS - AWS ElastiCache Redis
# ============================================
# Replace with your ElastiCache endpoint
REDIS_HOST=your-elasticache-endpoint.cache.amazonaws.com
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# ============================================
# STORAGE - AWS S3
# ============================================
STORAGE_MODE=s3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_S3_BUCKET=vs-platform-staging-uploads

# ============================================
# WORKER CONFIGURATION
# ============================================
# Adjust based on instance size and workload
TRANSCODING_CONCURRENCY=4
LIVE_STREAM_CONCURRENCY=2

# ============================================
# TEMPORARY DIRECTORY
# ============================================
TEMP_DIR=/tmp/transcode
