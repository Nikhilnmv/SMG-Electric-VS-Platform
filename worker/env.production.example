# ============================================
# WORKER - PRODUCTION CLOUD ENVIRONMENT
# ============================================
# Copy this file to .env for production deployment
# cp env.production.example .env
# Then fill in the actual values from your cloud infrastructure
# 
# IMPORTANT: Never commit production .env files to version control!
# Use secrets management (AWS Secrets Manager, etc.)

# Environment
NODE_ENV=production
ENVIRONMENT=production

# ============================================
# DATABASE - AWS RDS PostgreSQL
# ============================================
# Replace with your production RDS endpoint
DATABASE_URL=postgresql://username:password@your-prod-rds-endpoint.region.rds.amazonaws.com:5432/vs_platform?schema=public

# Alternative: Individual connection parameters
DB_HOST=your-prod-rds-endpoint.region.rds.amazonaws.com
DB_PORT=5432
DB_NAME=vs_platform
DB_USER=your_prod_db_username
DB_PASSWORD=your_prod_db_password

# ============================================
# REDIS - AWS ElastiCache Redis
# ============================================
# Replace with your production ElastiCache endpoint
REDIS_HOST=your-prod-elasticache-endpoint.cache.amazonaws.com
REDIS_PORT=6379
REDIS_PASSWORD=your_prod_redis_password
REDIS_DB=0

# ============================================
# STORAGE - AWS S3
# ============================================
STORAGE_MODE=s3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_prod_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_prod_aws_secret_access_key
AWS_S3_BUCKET=vs-platform-production-uploads

# ============================================
# WORKER CONFIGURATION
# ============================================
# Adjust based on instance size and workload
# Production typically uses higher concurrency
TRANSCODING_CONCURRENCY=8
LIVE_STREAM_CONCURRENCY=4

# ============================================
# TEMPORARY DIRECTORY
# ============================================
TEMP_DIR=/tmp/transcode
