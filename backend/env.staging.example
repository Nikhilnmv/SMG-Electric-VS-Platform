# ============================================
# STAGING CLOUD ENVIRONMENT
# ============================================
# Copy this file to .env for staging deployment
# cp env.staging.example .env
# Then fill in the actual values from your cloud infrastructure

# Environment
NODE_ENV=production
ENVIRONMENT=staging

# ============================================
# DATABASE - AWS RDS PostgreSQL
# ============================================
# Replace with your RDS endpoint
DATABASE_URL=postgresql://username:password@your-rds-endpoint.region.rds.amazonaws.com:5432/vs_platform?schema=public

# Alternative: Individual connection parameters
DB_HOST=your-rds-endpoint.region.rds.amazonaws.com
DB_PORT=5432
DB_NAME=vs_platform
DB_USER=your_db_username
DB_PASSWORD=your_db_password

# ============================================
# REDIS - AWS ElastiCache Redis
# ============================================
# Replace with your ElastiCache endpoint
REDIS_HOST=your-elasticache-endpoint.cache.amazonaws.com
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0
# Alternative: Redis URL format
# REDIS_URL=redis://:password@your-elasticache-endpoint.cache.amazonaws.com:6379/0

# ============================================
# CLICKHOUSE - ClickHouse Cloud
# ============================================
# Replace with your ClickHouse Cloud endpoint
CLICKHOUSE_HOST=your-clickhouse-host.clickhouse.cloud
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=default
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=your_clickhouse_password
CLICKHOUSE_PROTOCOL=https

# ============================================
# STORAGE - AWS S3
# ============================================
STORAGE_MODE=s3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_S3_BUCKET=vs-platform-staging-uploads

# ============================================
# CDN - AWS CloudFront
# ============================================
CDN_ENABLED=true
CDN_URL=https://your-cloudfront-distribution-id.cloudfront.net
CLOUDFRONT_URL=https://your-cloudfront-distribution-id.cloudfront.net

# ============================================
# SMTP - AWS SES
# ============================================
SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=your_ses_smtp_username
SMTP_PASS=your_ses_smtp_password
SMTP_FROM=noreply@yourdomain.com
SMTP_FROM_NAME=VS Platform
SMTP_SECURE=true

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3001
FRONTEND_ORIGIN=https://staging.yourdomain.com
ALLOWED_ORIGINS=https://staging.yourdomain.com,https://api-staging.yourdomain.com

# ============================================
# AUTHENTICATION
# ============================================
# IMPORTANT: Use a strong, randomly generated secret in staging
JWT_SECRET=your-strong-random-jwt-secret-here
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ============================================
# FRONTEND URL
# ============================================
FRONTEND_URL=https://staging.yourdomain.com

# ============================================
# PASSWORD RESET
# ============================================
PASSWORD_RESET_TOKEN_TTL_SECONDS=3600

# ============================================
# DEVELOPMENT MODE
# ============================================
DEV_MODE=false
DEV_EMAIL_DUMP=false

# ============================================
# TEMPORARY DIRECTORY
# ============================================
TEMP_DIR=/tmp/transcode
