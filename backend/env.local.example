# ============================================
# LOCAL DEVELOPMENT ENVIRONMENT
# ============================================
# Copy this file to .env for local development
# cp env.local.example .env

# Environment
NODE_ENV=development
ENVIRONMENT=local

# ============================================
# DATABASE - Local Docker PostgreSQL
# ============================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vs_platform?schema=public

# Alternative: Individual connection parameters
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vs_platform
DB_USER=postgres
DB_PASSWORD=postgres

# ============================================
# REDIS - Local Docker Redis
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
# Alternative: Redis URL format
# REDIS_URL=redis://localhost:6379/0

# ============================================
# CLICKHOUSE - Local Docker ClickHouse
# ============================================
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=default
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_PROTOCOL=http

# ============================================
# STORAGE - Local Filesystem
# ============================================
STORAGE_MODE=local
UPLOADS_DIR=./uploads
HLS_PREFIX_BY_CATEGORY=false

# AWS S3 (not used in local mode, but can be set for testing)
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# CLOUDFRONT_URL=

# ============================================
# CDN - Local Backend Paths
# ============================================
# In local mode, CDN is not used - files are served directly from backend
CDN_ENABLED=false
CDN_URL=

# ============================================
# SMTP - Local MailHog (for email testing)
# ============================================
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@vs-platform.local
SMTP_FROM_NAME=VS Platform (Local)
SMTP_SECURE=false

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3001
FRONTEND_ORIGIN=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================
# AUTHENTICATION
# ============================================
JWT_SECRET=dev-secret-key-change-in-production
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ============================================
# FRONTEND URL
# ============================================
FRONTEND_URL=http://localhost:3000

# ============================================
# PASSWORD RESET
# ============================================
PASSWORD_RESET_TOKEN_TTL_SECONDS=3600

# ============================================
# DEVELOPMENT MODE
# ============================================
DEV_MODE=true
DEV_EMAIL_DUMP=true

# ============================================
# TEMPORARY DIRECTORY
# ============================================
TEMP_DIR=/tmp/transcode
