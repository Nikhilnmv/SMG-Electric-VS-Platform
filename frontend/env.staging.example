# ============================================
# FRONTEND - STAGING CLOUD ENVIRONMENT
# ============================================
# Copy this file to .env.local for staging deployment
# cp env.staging.example .env.local
# Then fill in the actual values from your cloud infrastructure

# Environment
NODE_ENV=production
NEXT_PUBLIC_ENVIRONMENT=staging

# ============================================
# API CONFIGURATION
# ============================================
# Replace with your staging API URL
NEXT_PUBLIC_API_URL=https://api-staging.yourdomain.com

# ============================================
# AUTHENTICATION
# ============================================
NEXT_PUBLIC_JWT_STORAGE_KEY=vs_platform_token

# ============================================
# STORAGE MODE
# ============================================
NEXT_PUBLIC_STORAGE_MODE=s3

# ============================================
# AWS CONFIGURATION
# ============================================
NEXT_PUBLIC_AWS_REGION=us-east-1
NEXT_PUBLIC_S3_BUCKET=vs-platform-staging-uploads

# ============================================
# CDN CONFIGURATION
# ============================================
NEXT_PUBLIC_CDN_ENABLED=true
# Replace with your staging CloudFront distribution URL
NEXT_PUBLIC_CLOUD_FRONT_URL=https://your-staging-cloudfront-distribution-id.cloudfront.net
