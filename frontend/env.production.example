# ============================================
# FRONTEND - PRODUCTION CLOUD ENVIRONMENT
# ============================================
# Copy this file to .env.local for production deployment
# cp env.production.example .env.local
# Then fill in the actual values from your cloud infrastructure
# 
# IMPORTANT: Never commit production .env files to version control!

# Environment
NODE_ENV=production
NEXT_PUBLIC_ENVIRONMENT=production

# ============================================
# API CONFIGURATION
# ============================================
# Replace with your production API URL
NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# ============================================
# AUTHENTICATION
# ============================================
NEXT_PUBLIC_JWT_STORAGE_KEY=vs_platform_token

# ============================================
# STORAGE MODE
# ============================================
NEXT_PUBLIC_STORAGE_MODE=s3

# ============================================
# AWS CONFIGURATION
# ============================================
NEXT_PUBLIC_AWS_REGION=us-east-1
NEXT_PUBLIC_S3_BUCKET=vs-platform-production-uploads

# ============================================
# CDN CONFIGURATION
# ============================================
NEXT_PUBLIC_CDN_ENABLED=true
# Replace with your production CloudFront distribution URL
NEXT_PUBLIC_CLOUD_FRONT_URL=https://your-production-cloudfront-distribution-id.cloudfront.net
