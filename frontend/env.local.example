# ============================================
# FRONTEND - LOCAL DEVELOPMENT ENVIRONMENT
# ============================================
# Copy this file to .env.local for local development
# cp env.local.example .env.local

# Environment
NODE_ENV=development
NEXT_PUBLIC_ENVIRONMENT=local

# ============================================
# API CONFIGURATION
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:3001

# ============================================
# AUTHENTICATION
# ============================================
NEXT_PUBLIC_JWT_STORAGE_KEY=vs_platform_token

# ============================================
# STORAGE MODE
# ============================================
NEXT_PUBLIC_STORAGE_MODE=local

# ============================================
# AWS CONFIGURATION (not used in local mode)
# ============================================
# NEXT_PUBLIC_AWS_REGION=
# NEXT_PUBLIC_S3_BUCKET=

# ============================================
# CDN CONFIGURATION (not used in local mode)
# ============================================
# In local mode, files are served directly from backend
NEXT_PUBLIC_CDN_ENABLED=false
NEXT_PUBLIC_CLOUD_FRONT_URL=
